{
	"name": "davatar",
	"version": "2.7.5",
	"scripts": {
		"dev": "vite",
		"dev:mock": "vite dev --mode mock",
		"build": "rimraf dist/assets/* && vite build",
		"serve": "vite preview",
		"lint": "eslint --ext .js,.jsx,.ts,.tsx,.vue src",
		"bump": "bumpp package.json --commit \"release: v\" --push --tag",
		"up:deps": "taze major",
		"prepare": "npx simple-git-hooks"
	},
	"dependencies": {
		"@vueuse/components": "^10.9.0",
		"@vueuse/core": "^10.9.0",
		"axios": "^1.6.8",
		"hoci": "^0.5.9",
		"pinia": "^2.1.7",
		"query-string": "^8.2.0",
		"tslx": "^0.1.1",
		"vue": "^3.4.21",
		"vue-router": "^4.3.0",
		"vue-virtual-scroller": "2.0.0-beta.8",
		"workbox-expiration": "^7.0.0",
		"workbox-strategies": "^7.0.0"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,vue}": [
			"prettier --write",
			"eslint --fix"
		],
		"*.{css,less,scss}": [
			"prettier --write"
		]
	},
	"devDependencies": {
		"@curev/eslint-config": "^0.3.6",
		"@fourze/core": "^0.30.2",
		"@fourze/vite": "^0.30.2",
		"@iconify-json/ic": "^1.1.17",
		"@types/node": "^20.11.30",
		"@unocss/preset-icons": "^0.58.8",
		"@unocss/preset-mini": "^0.58.8",
		"@unocss/preset-uno": "^0.58.8",
		"@vitejs/plugin-vue": "^4.6.2",
		"@vitejs/plugin-vue-jsx": "^3.1.0",
		"bumpp": "^9.4.0",
		"eslint": "^8.57.0",
		"less": "^4.2.0",
		"lint-staged": "^15.2.2",
		"prettier": "^3.2.5",
		"rimraf": "^5.0.5",
		"sass": "^1.72.0",
		"simple-git-hooks": "^2.11.1",
		"taze": "^0.13.3",
		"typescript": "^5.4.3",
		"unocss": "^0.58.8",
		"unocss-preset-palette": "^0.3.5",
		"unplugin-vue-components": "^0.26.0",
		"vite": "^5.2.6",
		"vite-plugin-pwa": "^0.19.7",
		"workbox-core": "^7.0.0",
		"workbox-precaching": "^7.0.0",
		"workbox-routing": "^7.0.0",
		"workbox-window": "^7.0.0"
	}
}
